  "item": [
    {
      "name": "Create New Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Parse the JSON response body\r",
              "const responseData = pm.response.json();\r",
              "\r",
              "// 2. Extract the \"id\" property\r",
              "const receivedId = responseData.id;\r",
              "\r",
              "// 3. Store it in an environment variable\r",
              "// This allows you to use {{CART_ID}} in other request URLs or bodies\r",
              "if (receivedId) {\r",
              "    pm.environment.set(\"CART_ID\", receivedId);\r",
              "    console.log(\"ID successfully saved: \" + receivedId);\r",
              "} else {\r",
              "    pm.expect.fail(\"ID not found in the response body\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Origin",
            "value": "{{BASE_URL}}",
            "type": "text"
          },
          {
            "key": "X-CSRF-Token",
            "value": "dummy",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/carts",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "carts"
          ]
        }
      },
      "response": []
    },
    {
